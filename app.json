{
  "expo": {
    "name": "The Vault",
    "slug": "mtg-scanner",
    "version": "1.0.0",
    "scheme": "mtgscanner",
    "orientation": "portrait",
    "icon": "./assets/vault-icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/vault-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mtgscanner.app",
      "infoPlist": {
        "NSCameraUsageDescription": "MTG Scanner uses the camera to scan Magic: The Gathering cards.",
        "NSPhotoLibraryUsageDescription": "MTG Scanner can read card images from your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0f",
        "foregroundImage": "./assets/vault-icon.png",
        "backgroundImage": "./assets/vault-icon.png",
        "monochromeImage": "./assets/vault-icon.png"
      },
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"],
      "package": "com.mtgscanner.app",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/vault-icon.png",
      "name": "The Vault",
      "shortName": "The Vault",
      "description": "Scan and track your Magic: The Gathering card collection",
      "backgroundColor": "#0a0a0f",
      "themeColor": "#c89b3c"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "MTG Scanner uses the camera to scan Magic: The Gathering cards."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The Vault accesses your photos to import binder pages for scanning."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
